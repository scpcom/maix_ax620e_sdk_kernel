&pwm0 {
	status = "disabled";
};

&pwm1 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&uart1_txd_pwm06_pins>;
};

&pwm2 {
	status = "disabled";
};

&deb_gpio_lp {
	lp-status = <41 1>; /* use db_gpio41 as wakeup source */
	status = "okay";
};

&i2c0 {
	status = "okay";
	#address-cells = <0x1>;
	#size-cells = <0x0>;

	lt7911d: lt7911d@2b {
		compatible = "lontium,lt7911d";
		reg = <0x2b>;
		irq-gpio = <&ax_gpio1 29 0>;    /* GPIO1_A29 */
		reset-gpio = <&ax_gpio1 28 0>;  /* GPIO1_A28 */
		status = "okay";
	};

	accelerometer: accelerometer@19 {
		compatible = "silan,sc7a20";
		reg = <0x19>;
		status = "okay";
	};
};

&i2c_slv0 {
	status = "okay";
	#address-cells = <0x1>;
	#size-cells = <0x0>;

	i2c_slave_eeprom: i2c_slave_eeprom@55 {
		compatible = "axera,slave-24c02";
		reg = <0x40000055>;
		status = "okay";
	};
};

&ax_perf_bm {
	status = "okay";
};

&ax_firewall {
	status = "disabled";
};

&ddr_dfs {
       status = "okay";
};

&bwlimiter {
	status = "okay";
};

&ive {
	status = "okay";
};

&vdec {
	status = "okay";
};

&venc {
	status = "okay";
};

&jenc {
	status = "okay";
};

&tdp {
	status = "okay";
};

&gdc {
	status = "okay";
};

&vpp {
	status = "okay";
};

&axera_rtc_pwr {
	status = "okay";
};

&drm0 {
	status = "okay";
};

&drm1 {
	status = "okay";
};

&crtc0 {
	status = "okay";
